---
export const prerender = true;
import Layout from '../layouts/Layout.astro';
import Header from '../components/common/Header.astro';
import Footer from '../components/common/Footer.astro';
import { getEntry } from 'astro:content';
import { Phone, MapPin, ArrowRight } from 'lucide-react';

const settings = await getEntry('settings', 'global');
const phone = settings?.data?.phone || '(02) 2671-8910';
const callLink = `tel:${phone.replace(/[\s\-()]/g, '')}`;
---

<Layout
  title="預約掛號 | 周孟翰醫師"
  description="周孟翰醫師線上預約掛號系統建置中，歡迎來電諮詢。"
>
  <Header slot="header" />

  <main class="min-h-[70vh] flex items-center justify-center bg-bg py-20 px-6">
    <div class="max-w-lg w-full text-center space-y-8">

      {/* 開診公告 */}
      <div class="mx-auto w-24 h-24 rounded-full bg-accent/10 border-2 border-accent/40 flex items-center justify-center">
        <MapPin size={44} className="text-accent" />
      </div>

      {/* 標題 */}
      <div>
        <p class="text-accent font-black text-sm tracking-widest uppercase mb-2">Grand Opening</p>
        <h1 class="text-3xl md:text-4xl font-serif font-bold text-primary leading-tight mb-3">
          新店高美泌尿科診所正式開診
        </h1>
        <p class="text-text/60 text-base">歡迎前來就診</p>
      </div>

      {/* 說明卡片 */}
      <div class="bg-surface border border-gray-100 rounded-2xl p-6 text-left space-y-3 shadow-sm">
        <p class="font-bold text-primary text-sm">目前採現場掛號方式：</p>
        <ul class="space-y-2 text-sm text-text/70">
          <li class="flex items-start gap-2">
            <span class="text-accent font-black shrink-0 mt-0.5">✔</span>
            <span>請直接至診所現場掛號報到，無需事先預約</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="text-accent font-black shrink-0 mt-0.5">✔</span>
            <span>初診請於各診次結束前 30 分鐘到院，並攜帶健保卡</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="text-accent font-black shrink-0 mt-0.5">✔</span>
            <span>如需確認當日看診時間或有其他疑問，歡迎來電諮詢</span>
          </li>
        </ul>
      </div>

      {/* 電話按鈕 */}
      <a
        href={callLink}
        class="inline-flex items-center gap-3 px-8 py-4 bg-primary text-white text-lg font-bold rounded-full shadow-lg hover:bg-accent hover:-translate-y-1 transition-all duration-300"
      >
        <Phone size={22} />
        {phone}
      </a>

      {/* 門診資訊連結 */}
      <div>
        <a
          href="/#clinic"
          class="inline-flex items-center gap-2 text-sm font-bold text-accent hover:text-primary transition-colors group"
        >
          查看門診時刻表與交通資訊
          <ArrowRight size={14} className="group-hover:translate-x-1 transition-transform" />
        </a>
      </div>

    </div>
  </main>

  <Footer slot="footer" />
</Layout>

