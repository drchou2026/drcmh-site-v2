---
export const prerender = true;
import Layout from "../layouts/Layout.astro";
import Header from "../components/common/Header.astro";
import Footer from "../components/common/Footer.astro";
import NewsTicker from "../components/home/NewsTicker.astro";
import Hero from "../components/home/Hero.astro";
import Expertise from "../components/home/Expertise.astro";
import VideoHighlights from "../components/home/VideoHighlights.astro";
import FacebookFeedSection from "../components/home/FacebookFeedSection.astro";
import Faq from "../components/home/Faq.astro";
import About from "../components/home/About.astro";
import ClinicInfo from "../components/home/ClinicInfo.astro";
import BlogPreview from "../components/home/BlogPreview.astro";
import HomeSchema from "../components/home/HomeSchema.astro";
import doctorProfileImage from "../assets/drchou-profile-2.png";
---

<Layout
  title="周孟翰醫師｜新店泌尿科｜大坪林站泌尿專科"
  description="周孟翰醫師於新店高美泌尿科診所提供泌尿專科診療，診所位於新北市新店區、大坪林站旁，服務新店、七張、景美、文山區、中和與永和周邊民眾。"
  preloadImage={doctorProfileImage.src}
>
  <Header slot="header" />

  <NewsTicker />
  <Hero />

  <About />

  <Expertise />

  <VideoHighlights />

  <FacebookFeedSection />

  <Faq />

  <BlogPreview />

  <ClinicInfo />

  <HomeSchema />

  <Footer slot="footer" />
</Layout>
