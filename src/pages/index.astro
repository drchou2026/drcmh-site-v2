---
export const prerender = true;
import Layout from "../layouts/Layout.astro";
import Header from "../components/common/Header.astro";
import Footer from "../components/common/Footer.astro";
import NewsTicker from "../components/home/NewsTicker.astro";
import Hero from "../components/home/Hero.astro";
import Expertise from "../components/home/Expertise.astro";
import VideoHighlights from "../components/home/VideoHighlights.astro";
import Faq from "../components/home/Faq.astro";
import About from "../components/home/About.astro";
import ClinicInfo from "../components/home/ClinicInfo.astro";
import BlogPreview from "../components/home/BlogPreview.astro";
---

<Layout>
  <Header slot="header" />

  <NewsTicker />
  <Hero />

  <About />

  <Expertise />

  <VideoHighlights />

  <Faq />

  <BlogPreview />

  <ClinicInfo />

  <Footer slot="footer" />
</Layout>
