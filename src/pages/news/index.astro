---
export const prerender = true;
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/common/Header.astro';
import Footer from '../../components/common/Footer.astro';
import { getCollection } from 'astro:content';

// 1. 取得所有消息
const allNews = await getCollection('news');

// 2. 排序邏輯：置頂優先 -> 日期新到舊
const sortedNews = allNews.sort((a, b) => {
  if (a.data.isPinned && !b.data.isPinned) return -1;
  if (!a.data.isPinned && b.data.isPinned) return 1;
  return b.data.date.valueOf() - a.data.date.valueOf();
});

// 3. 提取所有分類 (用於篩選器)
// 我們手動定義順序，比較美觀，而不是用 Set 自動抓
const categories = [
  { id: 'all', label: '全部消息' },
  { id: 'announcement', label: '診所公告' },
  { id: 'closed', label: '停診通知' },
  { id: 'activity', label: '活動快訊' },
];

// 分類樣式對照表
const categoryStyle: Record<string, string> = {
  announcement: 'bg-green-50 text-green-600 border-green-100',
  closed: 'bg-red-50 text-red-600 border-red-100',
  activity: 'bg-amber-50 text-amber-600 border-amber-100',
};

function formatDate(date: Date) {
  return new Date(date).toLocaleDateString('zh-TW', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
}

// 簡單的摘要擷取函式 (去除 Markdown 符號與 HTML Entity)
function getExcerpt(body: string) {
  return body
    .replace(/<[^>]*>?/gm, '') // 去除 HTML tag
    .replace(/&[#A-Za-z0-9]+;/gm, ' ') // 替換 HTML Entity 為空白 (例如 &#x20;, &nbsp; 等)
    .replace(/[#*`\\]/g, '') // 去除 Markdown 符號（含硬換行反斜線）
    .substring(0, 80) + '...'; // 取前 80 字
}
---

<Layout 
  title="最新消息 | Dr. Chou 泌尿科診所"
  description="隨時掌握診所的最新動態、門診異動與衛教活動資訊。"
>
  
  <Header slot="header" />

  {/* === 1. Page Header (移植自 Blog) === */}
  <section class="py-16 bg-bg relative overflow-hidden">
    {/* 裝飾背景 */}
    <div class="absolute top-0 right-0 w-1/3 h-full bg-highlight/30 -skew-x-12 translate-x-20 z-0 pointer-events-none"></div>
    
    <div class="container mx-auto px-6 relative z-10 text-center">
      <h1 class="text-4xl md:text-5xl font-serif font-bold text-primary mb-4">最新消息</h1>
      <p class="text-text max-w-2xl mx-auto leading-relaxed">
        隨時掌握診所的最新動態。<br/>
        包含門診異動、休診公告與最新的衛教活動資訊。
      </p>
    </div>
  </section>

  {/* === 2. Filter & List === */}
  <section class="py-12 bg-surface min-h-screen">
    <div class="container mx-auto px-4 md:px-6 max-w-4xl">
      
      {/* 分類篩選器 */}
      <div class="flex flex-wrap justify-center gap-3 mb-12">
        {categories.map(cat => (
          <button 
            class={`filter-btn px-5 py-2 rounded-full text-sm font-bold transition-all border 
              ${cat.id === 'all' 
                ? 'bg-primary text-white border-transparent shadow-md active' 
                : 'bg-white text-text border-highlight shadow-sm'
              }`}
            data-filter={cat.id}
          >
            {cat.label}
          </button>
        ))}
      </div>

      {/* 條列式文章列表 */}
      <div class="space-y-4" id="news-list">
        {sortedNews.map((item) => {
          const catStyle = categoryStyle[item.data.category] || 'bg-gray-50 text-gray-600';
          const catLabel = categories.find(c => c.id === item.data.category)?.label || '公告';

          return (
            <a 
              href={`/news/${item.id}`}
              class="news-item group block bg-white rounded-xl p-4 md:p-6 shadow-sm border border-gray-100 hover:shadow-md hover:border-accent/30 transition-all duration-300 relative overflow-hidden"
              data-category={item.data.category}
            >
              {/* 置頂標籤 (右側背景裝飾) */}
              {item.data.isPinned && (
                <div class="absolute top-0 right-0 p-2 md:p-3">
                  <span class="inline-flex items-center gap-1 text-[10px] md:text-xs font-bold text-accent bg-accent/10 px-2 py-1 rounded-md">
                    <i class="fa-solid fa-thumbtack"></i> 置頂
                  </span>
                </div>
              )}

              <div class="flex flex-col md:flex-row md:items-start gap-3 md:gap-4">
                
                {/* 左側：日期與分類 */}
                <div class="flex flex-row md:flex-col items-center md:items-start gap-2 md:gap-2 min-w-[auto] md:min-w-[120px] shrink-0">
                  {/* 分類標籤 */}
                  <span class={`px-2 md:px-3 py-0.5 md:py-1 rounded-full text-[10px] md:text-xs font-bold border ${catStyle}`}>
                    {catLabel}
                  </span>
                  {/* 日期 */}
                  <span class="text-xs md:text-sm text-gray-400 font-medium">
                    {formatDate(item.data.date)}
                  </span>
                </div>

                {/* 右側：標題與摘要 */}
                <div class="flex-grow pr-0 md:pr-8">
                  <h2 class="text-base md:text-xl font-bold text-gray-800 mb-1 md:mb-2 group-hover:text-primary transition-colors flex items-center gap-2">
                    {item.data.title}
                    <i class="fa-solid fa-arrow-right opacity-0 -translate-x-2 group-hover:opacity-100 group-hover:translate-x-0 transition-all text-accent text-sm hidden md:inline-block"></i>
                  </h2>
                  <p class="text-gray-600 text-sm line-clamp-2 md:line-clamp-1 group-hover:text-gray-700 leading-relaxed">
                    {getExcerpt(item.body || '')}
                  </p>
                </div>

              </div>
            </a>
          );
        })}
      </div>

      {/* 無資料提示 */}
      <div id="no-results" class="hidden text-center py-20 bg-white rounded-xl border border-dashed border-gray-200 mt-8">
        <div class="text-4xl mb-4 text-gray-300">📭</div>
        <p class="text-gray-500">此分類目前沒有相關消息。</p>
      </div>

    </div>
  </section>

  <Footer slot="footer" />

</Layout>

<style>
  /* 篩選按鈕懸停效果 (比照影片頁) */
  .filter-btn:not(.active):hover {
    @apply border-accent text-accent -translate-y-0.5 shadow-lg;
  }
  
  /* 選中狀態 hover 時不顯示 accent 色，也不位移 */
  .filter-btn.active:hover {
    @apply transform-none text-white border-transparent cursor-default shadow-md;
  }
</style>

<script>
  // 前端篩選邏輯 (與 Blog 類似，但簡化過)
  document.addEventListener('astro:page-load', () => {
    const buttons = document.querySelectorAll('.filter-btn');
    const items = document.querySelectorAll('.news-item');
    const noResults = document.getElementById('no-results');

    if (!buttons.length) return;

    buttons.forEach(btn => {
      btn.addEventListener('click', (e) => {
        const target = e.currentTarget as HTMLElement;
        if (target.classList.contains('active')) return;

        // 1. 按鈕樣式切換
        buttons.forEach(b => {
          b.classList.remove('bg-primary', 'text-white', 'shadow-md', 'border-transparent', 'active');
          b.classList.add('bg-white', 'text-text', 'border-highlight', 'shadow-sm');
        });
        
        target.classList.remove('bg-white', 'text-text', 'border-highlight', 'shadow-sm');
        target.classList.add('bg-primary', 'text-white', 'shadow-md', 'border-transparent', 'active');

        // 2. 篩選內容
        const filter = target.getAttribute('data-filter');
        let count = 0;

        items.forEach(item => {
          const el = item as HTMLElement;
          const category = el.getAttribute('data-category');
          
          if (filter === 'all' || category === filter) {
            el.style.display = 'block';
            el.animate([
              { opacity: 0, transform: 'translateY(10px)' },
              { opacity: 1, transform: 'translateY(0)' }
            ], { duration: 300, fill: 'forwards' });
            count++;
          } else {
            el.style.display = 'none';
          }
        });

        // 3. 查無資料
        if (noResults) {
          noResults.style.display = count === 0 ? 'block' : 'none';
        }
      });
    });
  });
</script>