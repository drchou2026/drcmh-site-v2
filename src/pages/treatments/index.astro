---
export const prerender = true;
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/common/Header.astro";
import TreatmentsGrid from "../../components/shared/TreatmentsGrid.astro";
import { ArrowRight, ChevronRight } from "lucide-react";

const title = "主治項目 | 新店高美泌尿科 周孟翰醫師";
const description =
  "新店高美泌尿科診所周孟翰醫師提供排尿困擾、攝護腺肥大、性傳染病、微創手術、男性性功能與一般泌尿疾病的完整診治。捷運大坪林站步行1分鐘。";

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "首頁", item: "https://drcmh.com/" },
    { "@type": "ListItem", position: 2, name: "主治項目", item: "https://drcmh.com/treatments/" },
  ],
};

const medicalClinicSchema = {
  "@context": "https://schema.org",
  "@type": "MedicalClinic",
  "@id": "https://drcmh.com/#clinic",
  name: "新店高美泌尿科診所",
  url: "https://drcmh.com",
  telephone: "02-8911-6911",
  address: {
    "@type": "PostalAddress",
    streetAddress: "二十張路 5 號 1 樓",
    addressLocality: "新店區",
    addressRegion: "新北市",
    postalCode: "231",
    addressCountry: "TW",
  },
  medicalSpecialty: "Urology",
  availableService: [
    { "@type": "MedicalProcedure", name: "排尿困擾與攝護腺", url: "https://drcmh.com/treatments/urinary-prostate" },
    { "@type": "MedicalProcedure", name: "私密健康與性傳染病", url: "https://drcmh.com/treatments/sexual-health" },
    { "@type": "MedicalProcedure", name: "微創治療與手術", url: "https://drcmh.com/treatments/minimally-invasive" },
    { "@type": "MedicalProcedure", name: "男性性功能與荷爾蒙", url: "https://drcmh.com/treatments/male-sexual-health" },
    { "@type": "MedicalProcedure", name: "一般泌尿疾病", url: "https://drcmh.com/treatments/general-urology" },
  ],
  physician: {
    "@type": "Physician",
    "@id": "https://drcmh.com/#physician",
    name: "周孟翰",
    medicalSpecialty: "Urology",
  },
};
---

<Layout title={title} description={description}>
  <Header slot="header" />

  <script is:inline type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  <script is:inline type="application/ld+json" set:html={JSON.stringify(medicalClinicSchema)} />

  <!-- Breadcrumb -->
  <nav class="bg-bg border-b border-gray-100 py-3" aria-label="breadcrumb">
    <div class="container mx-auto px-6">
      <ol class="flex items-center gap-2 text-sm text-text/60">
        <li><a href="/" class="hover:text-primary transition-colors">首頁</a></li>
        <li><ChevronRight size={14} className="inline" /></li>
        <li class="text-primary font-medium">主治項目</li>
      </ol>
    </div>
  </nav>

  <!-- Hero -->
  <section class="bg-gradient-to-br from-primary/5 via-bg to-bg py-16 md:py-20">
    <div class="container mx-auto px-6 max-w-4xl text-center">
      <p class="text-accent font-bold text-xs tracking-[0.2em] uppercase mb-4">TREATMENTS</p>
      <h1 class="text-3xl md:text-4xl lg:text-5xl font-serif font-bold text-primary mb-6">
        主治項目
      </h1>
      <p class="text-text/70 text-lg max-w-2xl mx-auto leading-relaxed">
        周孟翰醫師於新店高美泌尿科診所，提供完整的泌尿科診療服務。
        請選擇與您症狀相關的項目，了解詳細的評估與治療說明。
      </p>
    </div>
  </section>

  <TreatmentsGrid showHeading={false} />

  <!-- Clinic Info Strip -->
  <section class="py-10 bg-bg border-t border-gray-100">
    <div class="container mx-auto px-6 max-w-4xl">
      <div class="flex flex-col md:flex-row items-center justify-between gap-6 text-center md:text-left">
        <div>
          <p class="font-bold text-primary text-lg">新店高美泌尿科診所</p>
          <p class="text-text/60 text-sm mt-1">新北市新店區二十張路 5 號 1 樓｜電話：02-8911-6911</p>
        </div>
        <a
          href="/booking"
          class="shrink-0 inline-flex items-center gap-2 px-8 py-3 bg-accent text-white font-bold rounded-full hover:bg-primary transition-colors duration-300"
        >
          <span>立即預約</span>
          <ArrowRight size={16} />
        </a>
      </div>
    </div>
  </section>
</Layout>
