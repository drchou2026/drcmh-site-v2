---
import { getEntry } from 'astro:content';
import { MapPin, Phone, Mail, ArrowUp } from 'lucide-react';

const currentYear = new Date().getFullYear();

// 🟢 改用 getEntry 從 Keystatic 讀取全域設定
const settings = await getEntry('settings', 'global');
const { doctorName, clinicName, address, phone, sidebarIntro, email, facebook, instagram, line } = settings.data;

const clinicInfo = {
  name: clinicName || "新店高美泌尿科診所",
  address: address || "新北市新店區二十張路5號1樓",
  email: email || "d10822201@gmail.com",
  phone: phone || "(診所電話建置中)"
};
---

<footer class="bg-primary text-white pt-16 pb-8 border-t border-white/5 relative overflow-hidden">
  <!-- 裝飾背景字 -->
  <div class="absolute top-0 right-0 text-[8rem] font-serif font-bold text-white/5 pointer-events-none select-none -translate-y-1/2 translate-x-1/4 whitespace-nowrap">
    下半身的守護者
  </div>

  <div class="container mx-auto px-6 relative z-10">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-12 mb-16">
      
      <!-- 品牌介紹 -->
      <div class="md:col-span-2 space-y-4">
        <div class="flex flex-col">
          <span class="font-serif text-2xl font-bold tracking-wide text-white">周孟翰醫師</span>
          <span class="text-[10px] text-accent tracking-[0.12em] font-semibold">泌尿專科．下半身的守護者</span>
        </div>
        <p class="text-white/90 text-sm leading-relaxed max-w-sm">
          {sidebarIntro}
        </p>
        
        {/* 社群連結 */}
        <div class="flex items-center gap-4 pt-2">
          {facebook && (
            <a 
              href={facebook} 
              target="_blank" 
              rel="noopener noreferrer"
              class="w-10 h-10 rounded-full bg-white/10 flex items-center justify-center hover:bg-[#1877F2] hover:text-white transition-all border border-white/10"
              title="Facebook"
            >
              <i class="fa-brands fa-facebook text-lg"></i>
            </a>
          )}
          {instagram && (
            <a 
              href={instagram} 
              target="_blank" 
              rel="noopener noreferrer"
              class="w-10 h-10 rounded-full bg-white/10 flex items-center justify-center hover:bg-[#E4405F] hover:text-white transition-all border border-white/10"
              title="Instagram"
            >
              <i class="fa-brands fa-instagram text-lg"></i>
            </a>
          )}
          {line && (
            <a 
              href={line} 
              target="_blank" 
              rel="noopener noreferrer"
              class="w-10 h-10 rounded-full bg-white/10 flex items-center justify-center hover:bg-[#00C300] hover:text-white transition-all border border-white/10"
              title="LINE"
            >
              <i class="fa-brands fa-line text-lg"></i>
            </a>
          )}
        </div>
      </div>

      <!-- 快速連結 -->
      <div>
        <h4 class="font-bold text-accent mb-6 text-sm tracking-wider">QUICK LINKS</h4>
        <ul class="space-y-3 text-sm text-white/90">
          <li><a href="/news" class="hover:text-white hover:translate-x-1 transition-all inline-block">最新消息</a></li>
          <li><a href="/#about" class="hover:text-white hover:translate-x-1 transition-all inline-block">關於醫師</a></li>
          <li><a href="/#expertise" class="hover:text-white hover:translate-x-1 transition-all inline-block">主治專長</a></li>
          <li><a href="/blog" class="hover:text-white hover:translate-x-1 transition-all inline-block">衛教專欄</a></li>
          <li><a href="/video" class="hover:text-white hover:translate-x-1 transition-all inline-block">影音專區</a></li>
          <li><a href="/#clinic" class="hover:text-white hover:translate-x-1 transition-all inline-block">門診資訊</a></li>
        </ul>
      </div>

      <!-- 聯絡資訊 -->
      <div>
        <h4 class="font-bold text-accent mb-6 text-sm tracking-wider">CONTACT</h4>
        <ul class="space-y-4 text-sm text-white/90">
          <li class="flex items-start gap-3">
            <MapPin size={18} className="mt-0.5 text-accent shrink-0" />
            <div class="flex flex-col">
              <span class="font-bold text-white">{clinicInfo.name}</span>
              <span class="text-xs opacity-80">{clinicInfo.address}</span>
            </div>
          </li>
          <li class="flex items-center gap-3">
            <Phone size={18} className="text-accent shrink-0" />
            <span>{clinicInfo.phone}</span>
          </li>
          <li class="flex items-center gap-3">
            <Mail size={18} className="text-accent shrink-0" />
            <span>{clinicInfo.email}</span>
          </li>
        </ul>
      </div>
    </div>

    <!-- Copyright -->
    <div class="pt-8 border-t border-white/10 flex flex-col md:flex-row justify-between items-center gap-4 text-xs text-white/70">
      <p>
        &copy; {currentYear} 
        
        {/* 🟢 隱藏的後台入口：包在名字上 */}
        <a 
          href="/admin" 
          class="cursor-text hover:text-inherit text-inherit no-underline"
          target="_blank" 
          rel="noopener noreferrer"
          title="Staff Only"
          aria-label="Admin Login"
        >
          Dr. Chou Meng-Han
        </a>
        
        . All rights reserved.
      </p>
      
      <div class="flex gap-6">
        <a href="/privacy" class="hover:text-white transition-colors">隱私權政策與免責聲明</a>
      </div>
      <div>
        <a href="#top" class="inline-flex items-center gap-1 text-white/80 hover:text-white transition-colors">
          <ArrowUp size={16} />
          回到頂部
        </a>
    </div>
  </div>
</footer>