---
import { Calendar, ArrowRight } from 'lucide-react';
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'blog'>; 
}

const { post } = Astro.props;
const blogImageModules = import.meta.glob<{ default: ImageMetadata }>(
  '/src/assets/images/blog/**/*.{avif,gif,jpeg,jpg,png,webp}',
  { eager: true }
);

// 🟢 1. 修復連結：處理 Astro v5 glob loader 的 ID
const slug = post.id.replace(/\.(mdoc|md|yaml|json)$/, '');

// 🟢 2. 新增：一個簡單的函式來清除 Markdown 符號 (轉成純文字)
function stripMarkdown(markdown: string | undefined) {
  if (!markdown) return '';
  return markdown
    .replace(/^#+\s+/gm, '')       // 移除標題 (## Title)
    .replace(/!\[.*?\]\(.*?\)/g, '') // 移除圖片 (![alt](url))
    .replace(/\[(.*?)\]\(.*?\)/g, '$1') // 移除連結但保留文字 ([text](url))
    .replace(/(\*\*|__)(.*?)\1/g, '$2') // 移除粗體 (**text**)
    .replace(/(\*|_)(.*?)\1/g, '$2')    // 移除斜體 (*text*)
    .replace(/^>\s+/gm, '')        // 移除引用 (> text)
    .replace(/`{1,3}.*?`{1,3}/g, '') // 移除程式碼區塊
    .replace(/\n/g, ' ')           // 把換行變成空白
    .trim();
}

// 從文章內容中抓第一張圖（支援 Markdown 與 HTML img）
function getFirstImageFromBody(markdown: string | undefined) {
  if (!markdown) return null;

  // Markdown 圖片語法：![alt](url)
  const markdownImageMatch = markdown.match(/!\[[^\]]*\]\(([^)\s]+)(?:\s+"[^"]*")?\)/);
  if (markdownImageMatch?.[1]) return markdownImageMatch[1];


  
  // HTML 圖片語法：<img src="..."> 或 <img src='...'>
  const htmlImageMatch = markdown.match(/<img[^>]+src=["']([^"']+)["'][^>]*>/i);
  if (htmlImageMatch?.[1]) return htmlImageMatch[1];

  return null;
}

function normalizeBodyImagePath(imagePath: string) {
  const decodedPath = decodeURIComponent(imagePath.trim());

  if (decodedPath.startsWith('../../assets/')) {
    return `/src/assets/${decodedPath.slice('../../assets/'.length)}`;
  }

  if (decodedPath.startsWith('/src/assets/')) {
    return decodedPath;
  }

  if (decodedPath.startsWith('src/assets/')) {
    return `/${decodedPath}`;
  }

  return decodedPath;
}

function resolveBodyImage(imagePath: string | null) {
  if (!imagePath) return null;

  const normalizedPath = normalizeBodyImagePath(imagePath);
  const assetModule = blogImageModules[normalizedPath];

  if (assetModule?.default) {
    return { asset: assetModule.default, url: null };
  }

  return { asset: null, url: normalizedPath };
}

// 🟢 3. 邏輯升級：
// 優先順序：手動摘要 > SEO 描述 > 自動抓前 60 字 > 預設文字
const advancedData = post.data.advanced?.discriminant ? post.data.advanced.value : null;

// 自動產生摘要 (從 body 抓取，如果 body 是空的就給空字串)
const autoExcerpt = stripMarkdown(post.body).substring(0, 50) + (post.body && post.body.length > 60 ? '...' : '');
const firstBodyImage = getFirstImageFromBody(post.body);
const resolvedBodyImage = resolveBodyImage(firstBodyImage);

const excerpt = advancedData?.excerpt || advancedData?.seoDescription || autoExcerpt || '點擊閱讀全文...';
const cardExcerpt = excerpt.length > 40 ? `${excerpt.slice(0, 40)}...` : excerpt;
// 格式化日期
const formattedDate = post.data.date.toISOString().split('T')[0].replace(/-/g, '.');
---

<article 
  class="blog-card group flex flex-col h-full bg-surface rounded-2xl overflow-hidden border border-gray-120 hover:border-accent/20 hover:shadow-xl transition-all duration-300 cursor-pointer"
  data-tags={(post.data.tags || []).join(',')}
  data-categories={(post.data.category || []).join(',')}
>
  <a href={`/blog/${slug}`} class="flex flex-col h-full">
    
    {/* 封面圖區域 (固定比例 16:9) */}
    <div class="relative aspect-video overflow-hidden bg-gray-200">
      {post.data.coverImage ? (
        <Image 
          src={post.data.coverImage} 
          alt={post.data.title}
          class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
        />
      ) : resolvedBodyImage?.asset ? (
        <Image
          src={resolvedBodyImage.asset}
          alt={post.data.title}
          class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
        />
      ) : resolvedBodyImage?.url ? (
        <img
          src={resolvedBodyImage.url}
          alt={post.data.title}
          class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
          loading="lazy"
        />
      ) : (
        // 🟢 3. 無圖時的優化：使用漸層標題字卡 (取代原本單調的 icon)
        <div class="w-full h-full flex items-center justify-center p-6 bg-gradient-to-br from-primary/5 via-bg to-accent/10 group-hover:from-primary/10 group-hover:to-accent/20 transition-colors">
           <h3 class="text-xl font-serif font-bold text-primary/80 text-center leading-tight line-clamp-3 group-hover:text-primary">
             {cardExcerpt}
           </h3>
        </div>
      )}
      

    </div>

    {/* 內容區域 */}
    <div class="p-5 flex flex-col flex-grow">
      
      {/* Meta 資訊 (日期 + 第二個標籤) */}
      <div class="flex items-center gap-3 mb-2 text-xs text-text/60">
        <div class="flex items-center gap-1">
          <Calendar size={12} />
          <span>{formattedDate}</span>
        </div>
        

      </div>

      {/* 標題 */}
      <h3 class="text-xl font-serif font-bold text-primary mb-2 leading-snug line-clamp-2 group-hover:text-accent transition-colors">
        {post.data.title}
      </h3>

      {/* 標題下方顯示所有標籤 (限制單行，超出隱藏) */}
      {post.data.tags && post.data.tags.length > 0 && (
        <div 
          class="flex flex-nowrap gap-2 mb-4 overflow-hidden mask-right"
          style="-webkit-mask-image: linear-gradient(to right, black 70%, transparent 100%); mask-image: linear-gradient(to right, black 70%, transparent 100%);"
        >
          {post.data.tags.map((tag) => (
            <span class="px-2 py-1 rounded-md bg-gray-100 text-gray-600 text-xs font-medium group-hover:bg-primary/10 group-hover:text-primary transition-colors whitespace-nowrap shrink-0 border border-gray-100/50">
              #{tag}
            </span>
          ))}
        </div>
      )}

      {/* 底部按鈕區 (Read More + Arrow) */}
      <div class="pt-3 border-t border-primary/5 flex items-center justify-between mt-auto">
        <span class="text-sm font-bold text-primary group-hover:text-accent transition-colors">閱讀全文</span>
        <div class="w-8 h-8 rounded-full bg-white flex items-center justify-center text-primary shadow-sm border border-gray-100 group-hover:bg-accent group-hover:text-white group-hover:border-accent transition-all duration-300 transform group-hover:translate-x-1">
          <ArrowRight size={14} />
        </div>
      </div>

    </div>
  </a>
</article>