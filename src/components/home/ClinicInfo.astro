---
import { getEntry } from 'astro:content';
import { MapPin, Phone, Mail, Clock, Calendar, ExternalLink } from 'lucide-react';

// 🟢 從 Keystatic 讀取全域設定
const settings = await getEntry('settings', 'global');
const { doctorName, doctorTitle, clinicName, address, phone, email, bookingLink, googleMapEmbedLink } = settings.data;

// 🟢 從 Keystatic 讀取門診表設定
const scheduleData = await getEntry('schedule', 'timetable');

const clinicData = {
  name: clinicName || "新店高美泌尿科診所",
  doctor: "周孟翰",
  title: doctorTitle || "院長",
  address: address || "新北市新店區二十張路5號1樓",
  phone: phone || "(診所電話建置中)", 
  email: email || "d10822201@gmail.com",
  mapLink: googleMapEmbedLink || "https://www.google.com/maps/search/?api=1&query=新北市新店區二十張路5號1樓",
  mapEmbedLink: googleMapEmbedLink?.includes('/maps/embed') || googleMapEmbedLink?.includes('output=embed')
    ? googleMapEmbedLink
    : `https://www.google.com/maps?q=${encodeURIComponent(address || '新北市新店區二十張路5號1樓')}&output=embed`,
  navigationLink: `https://www.google.com/maps/dir/?api=1&destination=${encodeURIComponent(address || '新北市新店區二十張路5號1樓')}`,
  callLink: `tel:${(phone || '').replace(/\s/g, '')}`,
  bookingLink: bookingLink || "#",
};

// 門診表設定
const weeklySchedule = scheduleData?.data?.weeklySchedule || [];
const lastUpdated = scheduleData?.data?.lastUpdated;

// 格式化日期 (YYYY-MM-DD -> YYYY/MM/DD)
const formattedUpdatedDate = lastUpdated 
  ? new Date(lastUpdated).toLocaleDateString('zh-TW', { year: 'numeric', month: '2-digit', day: '2-digit' })
  : '';

// 預設門診表 (當 Keystatic 尚未設定時的備分)
const defaultSchedule = [
  { day: "週一", morning: { status: "看診" }, afternoon: { status: "看診" }, evening: { status: "看診" } },
  { day: "週二", morning: { status: "休診" }, afternoon: { status: "看診" }, evening: { status: "看診" } },
  { day: "週三", morning: { status: "看診" }, afternoon: { status: "休診" }, evening: { status: "看診" } },
  { day: "週四", morning: { status: "休診" }, afternoon: { status: "看診" }, evening: { status: "看診" } },
  { day: "週五", morning: { status: "看診" }, afternoon: { status: "看診" }, evening: { status: "休診" } },
  { day: "週六", morning: { status: "看診" }, afternoon: { status: "休診" }, evening: { status: "休診" } },
];

const displaySchedule = weeklySchedule.length > 0 ? weeklySchedule : defaultSchedule;

// 輔助函式：取得顯示文字
const getStatusLabel = (slot) => {
  if (!slot) return '-';
  if (slot.status === '自訂') return slot.customLabel || '-';
  if (slot.status === '看診') return '✔'; // 使用 Heavy Check Mark (粗勾勾)
  if (slot.status === '休診') return '-';
  if (slot.status === '特約診') return '特約';
  if (slot.status === '手術日') return '手術';
  return slot.status;
};

// 輔助函式：取得樣式
const getStatusClass = (status) => {
   if (status === '看診') return 'text-accent font-bold bg-accent/10';
   if (status === '休診') return 'text-text/20';
   if (status === '特約診') return 'text-red-500 font-bold bg-red-100';
   if (status === '手術日') return 'text-blue-500 font-bold bg-blue-100';
   if (status === '自訂') return 'text-primary font-bold bg-gray-100';
   return 'text-text/20';
};
---

<section id="clinic" class="py-24 bg-bg relative overflow-hidden">
  
  {/* 背景裝飾：右側傾斜色塊 */}
  <div class="absolute top-0 right-0 w-1/3 h-full bg-highlight/30 -skew-x-12 translate-x-20 z-0 pointer-events-none"></div>

  <div class="container mx-auto px-6 relative z-10">
    
    {/* 標題區塊 */}
    <div class="mb-16 text-center md:text-left">
      <h3 class="text-xs font-bold tracking-[0.2em] uppercase text-accent mb-3">CLINIC INFO</h3>
      <h2 class="text-3xl md:text-4xl font-serif font-bold text-primary">門診資訊</h2>
    </div>

    <div class="flex flex-col lg:flex-row gap-12 lg:gap-20">
      
      {/* 左側：診所詳情卡片 */}
      <div class="lg:w-1/2">
        <div class="bg-surface border border-white/50 shadow-2xl rounded-3xl p-8 md:p-12 relative overflow-hidden group">
          
          {/* 裝飾光暈 */}
          <div class="absolute -top-24 -right-24 w-48 h-48 bg-accent/10 rounded-full blur-3xl group-hover:bg-accent/20 transition-colors duration-500"></div>

          {/* 標籤 */}
          <div class="inline-block px-4 py-1.5 bg-primary text-white text-xs font-bold tracking-wider rounded-md mb-8 shadow-md">
            CURRENT LOCATION
          </div>

          {/* 診所名稱 */}
          <h3 class="text-3xl font-serif font-bold text-primary mb-2">
            {clinicData.name}
          </h3>
          <p class="text-accent font-medium mb-10 text-lg flex items-center gap-2">
            <span class="w-8 h-0.5 bg-accent inline-block"></span>
            {clinicData.title} | {clinicData.doctor} 醫師
          </p>

          {/* 聯絡資訊列表 */}
          <div class="space-y-8">
            
            {/* 地址 */}
            <div class="flex items-start gap-5">
              <div class="w-10 h-10 rounded-full bg-bg flex items-center justify-center text-accent shrink-0 mt-1">
                <MapPin size={20} />
              </div>
              <div>
                <p class="text-xs font-bold text-text/40 uppercase tracking-widest mb-1">Address</p>
                <p class="text-lg text-primary font-medium">{clinicData.address}</p>
                <div class="mt-3 flex flex-wrap gap-2">
                  <a 
                    href={clinicData.navigationLink} 
                    target="_blank" 
                    rel="noopener noreferrer"
                    class="inline-flex items-center gap-1 text-sm font-bold text-white bg-primary hover:bg-accent px-3 py-1.5 rounded-lg transition-colors"
                  >
                    一鍵導航 <ExternalLink size={14} />
                  </a>
                  <a 
                    href={clinicData.mapLink} 
                    target="_blank" 
                    rel="noopener noreferrer"
                    class="inline-flex items-center gap-1 text-sm font-bold text-primary border border-primary/25 hover:border-accent hover:text-accent px-3 py-1.5 rounded-lg transition-colors"
                  >
                    查看地圖 <ExternalLink size={14} />
                  </a>
                </div>
              </div>
            </div>
            
            {/* 電話 */}
            <div class="flex items-start gap-5">
              <div class="w-10 h-10 rounded-full bg-bg flex items-center justify-center text-accent shrink-0 mt-1">
                <Phone size={20} />
              </div>
              <div>
                <p class="text-xs font-bold text-text/40 uppercase tracking-widest mb-1">Phone</p>
                <div class="flex flex-wrap items-center gap-3">
                  <p class="text-lg text-primary font-medium">{clinicData.phone}</p>
                  <a
                    href={clinicData.callLink}
                    class="inline-flex items-center text-sm font-bold text-accent border-b border-accent/30 pb-0.5 hover:text-primary hover:border-primary transition-colors"
                  >
                    一鍵撥號
                  </a>
                </div>
              </div>
            </div>

            {/* Email */}
            <div class="flex items-start gap-5">
              <div class="w-10 h-10 rounded-full bg-bg flex items-center justify-center text-accent shrink-0 mt-1">
                <Mail size={20} />
              </div>
              <div>
                <p class="text-xs font-bold text-text/40 uppercase tracking-widest mb-1">Email</p>
                <p class="text-lg text-primary font-medium break-all">{clinicData.email}</p>
              </div>
            </div>

          </div>

          <div class="mt-10 rounded-2xl overflow-hidden border border-white/60 shadow-sm">
            <iframe
              title={`${clinicData.name} 地圖`}
              src={clinicData.mapEmbedLink}
              class="w-full h-[260px]"
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              allowfullscreen
            ></iframe>
          </div>

          {/* CTA 按鈕 */}
          <div class="mt-12 pt-8 border-t border-gray-100">
            <button
              type="button"
              disabled
              aria-disabled="true"
              class="block w-full text-center py-4 bg-gray-300 text-white font-bold rounded-xl cursor-not-allowed"
            >
              建置中
            </button>
            <p class="text-center text-xs text-text/50 mt-3">
              * 線上掛號功能準備中
            </p>
          </div>

        </div>
      </div>

      {/* 右側：門診時間表 */}
      <div class="lg:w-1/2 flex flex-col justify-center">
        
        <div class="mb-8 flex items-center gap-3">
           <div class="p-3 bg-white rounded-full text-accent shadow-sm">
             <Clock size={24} />
           </div>
           <div>
             <h3 class="text-xl font-bold text-primary flex items-center gap-3">
               門診時刻表
               {formattedUpdatedDate && (
                 <span class="text-[0.65rem] font-normal bg-accent/10 text-accent px-2 py-0.5 rounded-full border border-accent/20">
                   更新日期：{formattedUpdatedDate}
                 </span>
               )}
             </h3>
             <p class="text-sm text-text/60">週日休診，國定假日請見公告</p>
           </div>
        </div>
        
        <div class="bg-surface rounded-3xl p-6 md:p-10 shadow-sm border border-white/50">
           {/* 表頭 */}
           <div class="grid grid-cols-4 gap-4 mb-6 text-center">
              <div class="text-text/40 font-bold text-sm flex items-center justify-center">
                <Calendar size={16} />
              </div>
              <div class="text-primary font-bold text-sm bg-highlight/50 py-2 rounded-lg">早診 (09:00-12:00)</div>
              <div class="text-primary font-bold text-sm bg-highlight/50 py-2 rounded-lg">午診 (14:30-17:30)</div>
              <div class="text-primary font-bold text-sm bg-highlight/50 py-2 rounded-lg">夜診 (18:30-20:30)</div>
           </div>
           
           {/* 表格內容 */}
           <div class="space-y-3">
              {displaySchedule.map((s) => (
                 <div class="grid grid-cols-4 gap-4 items-center text-center group hover:bg-bg/50 rounded-xl transition-colors py-2 px-1">
                    {/* 星期 */}
                    <div class="font-bold text-primary text-sm group-hover:text-accent transition-colors">
                      {s.day}
                    </div>
                    
                    {/* 早診 */}
                    <div class={`text-sm py-2 rounded-lg flex flex-col justify-center items-center transition-all ${getStatusClass(s.morning?.status)}`}>
                       <span>{getStatusLabel(s.morning)}</span>
                       {s.morning?.note && <span class="text-[0.6rem] opacity-70 mt-0.5 font-normal">{s.morning.note}</span>}
                    </div>
                    
                    {/* 午診 */}
                    <div class={`text-sm py-2 rounded-lg flex flex-col justify-center items-center transition-all ${getStatusClass(s.afternoon?.status)}`}>
                       <span>{getStatusLabel(s.afternoon)}</span>
                       {s.afternoon?.note && <span class="text-[0.6rem] opacity-70 mt-0.5 font-normal">{s.afternoon.note}</span>}
                    </div>
                    
                    {/* 晚診 */}
                    <div class={`text-sm py-2 rounded-lg flex flex-col justify-center items-center transition-all ${getStatusClass(s.evening?.status)}`}>
                       <span>{getStatusLabel(s.evening)}</span>
                       {s.evening?.note && <span class="text-[0.6rem] opacity-70 mt-0.5 font-normal">{s.evening.note}</span>}
                    </div>
                 </div>
              ))}
           </div>

           <div class="mt-8 p-4 bg-highlight/30 rounded-xl border border-highlight/50 text-xs text-text/70 leading-relaxed flex gap-3">
              <div class="mt-0.5 min-w-[16px] text-accent">!</div>
              <p>
                實際看診時間可能因會議或手術有所異動，建議看診前先透過電話或線上系統確認。
              </p>
           </div>
        </div>
      </div>

    </div>
  </div>
</section>