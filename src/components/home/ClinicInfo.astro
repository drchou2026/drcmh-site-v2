---
import { Image } from "astro:assets";
import BankImg from "../../assets/images/parking-next-to-bank.jpg";
import Jmart1Img from "../../assets/images/parking-times-JMART1.jpg";
import Jmart2Img from "../../assets/images/parking-times-JMART2.jpg";
import MapImg from "../../assets/images/XDGM-parking-map.jpg";
import { getEntry } from "astro:content";
import {
  MapPin,
  Phone,
  Clock,
  Calendar,
  Navigation,
  Train,
  Bus,
  CarFront,
  Bike,
  Mail,
} from "lucide-react";

// 🟢 從 Keystatic 讀取全域設定
const settings = await getEntry("settings", "global");
if (!settings) throw new Error("global settings not found");
const {
  doctorName,
  doctorTitle,
  clinicName,
  address,
  phone,
  bookingLink,
  googleMapEmbedLink,
  email,
} = settings.data;

// 🟢 從 Keystatic 讀取門診表設定
const scheduleData = await getEntry("schedule", "timetable");

const fallbackAddress = "231 新北市新店區二十張路 5 號 1 樓";
const fallbackPhone = "(02) 2671-8910";
const fallbackGoogleMapPageUrl = "https://maps.app.goo.gl/MU3R8XXKV7bweCAU9";
const fallbackGoogleMapEmbedUrl =
  "https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3616.51512190352!2d121.53749303737627!3d24.98260654045585!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x346801201ea578d5%3A0x5b4d80d552da23c9!2z5paw5bqX6auY576O5rOM5bC_56eR6Ki15omA!5e0!3m2!1szh-TW!2stw!4v1775477814530!5m2!1szh-TW!2stw";

const rawMapInput = (googleMapEmbedLink || "").trim();
const iframeSrcMatch = rawMapInput.match(/src=["']([^"']+)["']/i);
const normalizedMapInput = iframeSrcMatch?.[1] || rawMapInput;
const selectedMapInput = normalizedMapInput || fallbackGoogleMapEmbedUrl;
const isEmbedUrl =
  selectedMapInput.includes("/maps/embed") ||
  selectedMapInput.includes("output=embed") ||
  selectedMapInput.includes("pb=!");

const clinicData = {
  name: clinicName || "新店高美泌尿科診所",
  doctor: doctorName || "周孟翰",
  title: doctorTitle || "院長",
  address: address || fallbackAddress,
  phone: phone || fallbackPhone,
  mapEmbedLink: isEmbedUrl
    ? selectedMapInput
    : `https://www.google.com/maps?q=${encodeURIComponent(selectedMapInput)}&output=embed`,
  mapLink: isEmbedUrl ? fallbackGoogleMapPageUrl : selectedMapInput,
  navigationLink: isEmbedUrl ? fallbackGoogleMapPageUrl : selectedMapInput,
  callLink: `tel:${(phone || fallbackPhone).replace(/[\s\-()]/g, "")}`,
};

// 門診表設定
const weeklySchedule = scheduleData?.data?.weeklySchedule || [];
const lastUpdated = scheduleData?.data?.lastUpdated;

const formattedUpdatedDate = lastUpdated
  ? new Date(lastUpdated).toLocaleDateString("zh-TW", {
      year: "numeric",
      month: "2-digit",
      day: "2-digit",
    })
  : "";

type SlotType = { status: string; customLabel?: string; note?: string };
type ScheduleRow = {
  day: string;
  morning: SlotType;
  afternoon: SlotType;
  evening: SlotType;
};

const defaultSchedule: ScheduleRow[] = [
  {
    day: "週一",
    morning: { status: "看診" },
    afternoon: { status: "看診" },
    evening: { status: "看診" },
  },
  {
    day: "週二",
    morning: { status: "休診" },
    afternoon: { status: "看診" },
    evening: { status: "看診" },
  },
  {
    day: "週三",
    morning: { status: "看診" },
    afternoon: { status: "休診" },
    evening: { status: "看診" },
  },
  {
    day: "週四",
    morning: { status: "休診" },
    afternoon: { status: "看診" },
    evening: { status: "看診" },
  },
  {
    day: "週五",
    morning: { status: "看診" },
    afternoon: { status: "看診" },
    evening: { status: "休診" },
  },
  {
    day: "週六",
    morning: { status: "看診" },
    afternoon: { status: "休診" },
    evening: { status: "休診" },
  },
];

const displaySchedule: ScheduleRow[] =
  weeklySchedule.length > 0
    ? (weeklySchedule as ScheduleRow[])
    : defaultSchedule;

const getStatusLabel = (slot: any) => {
  if (!slot) return "-";
  if (slot.status === "自訂") return slot.customLabel || "-";
  if (slot.status === "看診") return "✔";
  if (slot.status === "休診") return "-";
  if (slot.status === "特約診") return "特約";
  if (slot.status === "手術日") return "手術";
  return slot.status;
};

const getStatusClass = (status: string) => {
  if (status === "看診") return "text-accent font-bold bg-accent/10";
  if (status === "休診") return "text-text/20";
  if (status === "特約診") return "text-red-500 font-bold bg-red-100";
  if (status === "手術日") return "text-red-500 font-bold bg-red-100";
  if (status === "自訂") return "text-primary font-bold bg-gray-100";
  return "text-text/20";
};
---

<section
  id="clinic"
  class="py-24 bg-bg relative overflow-hidden"
  aria-label="門診資訊"
>
  {/* 背景裝飾 */}
  <div
    class="absolute top-0 right-0 w-1/3 h-full bg-highlight/30 -skew-x-12 translate-x-20 z-0 pointer-events-none"
    aria-hidden="true"
  >
  </div>

  <div
    class="container mx-auto px-4 sm:px-6 relative z-10 space-y-24 lg:space-y-28"
  >
    {/* ── 上半部：駐診與門診時刻表 ── */}
    <div
      class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-12 max-w-6xl mx-auto w-full items-stretch"
    >
      {/* 左欄：目前所在診所、個人聯絡email */}
      <div class="flex flex-col">
        <div class="mb-10 text-left">
          <p
            class="text-xs font-bold tracking-[0.2em] uppercase text-accent mb-3 flex items-center justify-start gap-2"
          >
            <MapPin size={14} aria-hidden="true" /> CLINIC INFO
          </p>
          <h2 class="text-3xl md:text-4xl font-serif font-bold text-primary">
            門診與聯絡資訊
          </h2>
        </div>

        <div
          class="bg-surface rounded-3xl p-6 sm:p-8 md:p-10 shadow-xl border border-white/80 space-y-6 flex-1 flex flex-col"
        >
          {/* 目前看診地點 */}
          <div class="flex items-start gap-4">
            <div
              class="w-12 h-12 rounded-2xl bg-blue-50 border border-blue-100 flex items-center justify-center text-primary shrink-0 mt-0.5"
              aria-hidden="true"
            >
              <MapPin size={24} strokeWidth={2.5} />
            </div>
            <div>
              <h3
                class="text-xs font-bold text-text/40 uppercase tracking-widest mb-1.5"
              >
                目前看診地點
              </h3>
              <p
                class="text-xl md:text-2xl font-bold text-primary leading-tight"
              >
                {clinicData.name}
              </p>
              <p
                class="text-xl md:text-2xl font-bold text-primary leading-tight"
              >
                三軍總醫院汀州院區
              </p>
            </div>
          </div>

          <div class="w-full h-px bg-gray-100" aria-hidden="true"></div>

          {/* 電話 */}
          <div class="flex items-start gap-4">
            <div
              class="w-12 h-12 rounded-2xl bg-green-50 border border-green-100 flex items-center justify-center text-green-700 shrink-0 mt-0.5"
              aria-hidden="true"
            >
              <Phone size={24} strokeWidth={2.5} />
            </div>
            <div class="min-w-0 flex-1">
              <h3
                class="text-xs font-bold text-text/40 uppercase tracking-widest mb-1.5"
              >
                診所電話
              </h3>
              <a
                href={clinicData.callLink}
                class="text-xl md:text-2xl font-bold text-primary hover:text-accent transition-colors"
              >
                {clinicData.phone}
              </a>
            </div>
          </div>

          <div class="w-full h-px bg-gray-100" aria-hidden="true"></div>

          {/* Email */}
          <div class="flex items-start gap-4">
            <div
              class="w-12 h-12 rounded-2xl bg-highlight/50 border border-highlight flex items-center justify-center text-accent shrink-0 mt-0.5"
              aria-hidden="true"
            >
              <Mail size={24} strokeWidth={2.5} />
            </div>
            <div class="min-w-0">
              <h3
                class="text-xs font-bold text-text/40 uppercase tracking-widest mb-1.5"
              >
                個人聯絡 Email
              </h3>
              {
                email ? (
                  <a
                    href={`mailto:${email}`}
                    class="text-lg font-bold text-primary hover:text-accent transition-colors block break-words"
                  >
                    {email}
                  </a>
                ) : (
                  <p class="text-lg font-bold text-primary">暫無提供</p>
                )
              }
            </div>
          </div>

          <div class="w-full h-px bg-gray-100" aria-hidden="true"></div>

          {/* 就診前須知 */}
          <div class="flex-1 flex flex-col justify-end space-y-3">
            <h3
              class="text-md font-bold text-text/40 uppercase tracking-widest"
            >
              就診前須知
            </h3>
            <ul class="space-y-2.5">
              {
                [
                  "初診請提前 10 分鐘報到，並攜帶健保卡",
                  "如需取消或改期，請提前來電告知",
                  "實際看診時間可能因手術有所異動",
                  "隱私保密，所有就診資料嚴格保護",
                ].map((item) => (
                  <li class="flex items-start gap-2.5 text-md text-text/70 leading-relaxed">
                    <span
                      class="w-1.5 h-1.5 rounded-full bg-accent mt-2 shrink-0"
                      aria-hidden="true"
                    />
                    {item}
                  </li>
                ))
              }
            </ul>
          </div>
        </div>
      </div>

      {/* 右欄：門診時刻表 */}
      <div class="flex flex-col">
        <div class="mb-10 text-left lg:text-center">
          <p
            class="text-xs font-bold tracking-[0.2em] uppercase text-accent mb-3 flex items-center justify-start lg:justify-center gap-2"
          >
            <Clock size={14} aria-hidden="true" /> SCHEDULE
          </p>
          <h2
            class="text-3xl md:text-4xl font-serif font-bold text-primary flex flex-col sm:flex-row items-start lg:items-center justify-start lg:justify-center gap-3"
          >
            門診時刻表
            {
              formattedUpdatedDate && (
                <span class="text-[0.65rem] font-normal leading-none bg-accent/10 text-accent px-3 py-1.5 rounded-full border border-accent/20 shadow-sm mt-1 sm:mt-0">
                  更新日期：{formattedUpdatedDate}
                </span>
              )
            }
          </h2>
          <p class="text-sm text-text/60 mt-3">
            週日休診，國定假日請見首頁公告
          </p>
        </div>

        <div
          class="bg-surface rounded-3xl p-5 sm:p-8 md:p-10 shadow-xl border border-white/80 flex-1 flex flex-col"
        >
          {/* 表頭 */}
          <div class="grid grid-cols-4 gap-2 sm:gap-4 mb-4 sm:mb-6 text-center">
            <div
              class="text-text/40 font-bold text-sm flex items-center justify-center bg-gray-50/50 rounded-xl py-2"
              aria-hidden="true"
            >
              <Calendar size={18} />
            </div>
            <div
              class="text-primary font-bold text-sm sm:text-sm bg-highlight/50 py-2.5 rounded-xl leading-tight"
            >
              早診<span class="block text-sm font-normal opacity-100 mt-0.5"
                >09:00–12:00</span
              >
            </div>
            <div
              class="text-primary font-bold text-sm sm:text-sm bg-highlight/50 py-2.5 rounded-xl leading-tight"
            >
              午診<span class="block text-sm font-normal opacity-100 mt-0.5"
                >14:30–17:30</span
              >
            </div>
            <div
              class="text-primary font-bold text-sm sm:text-sm bg-highlight/50 py-2.5 rounded-xl leading-tight"
            >
              夜診<span class="block text-sm font-normal opacity-100 mt-0.5"
                >18:30–20:30</span
              >
            </div>
          </div>

          {/* 表格列 */}
          <div
            class="space-y-2 sm:space-y-3 flex-1"
            role="list"
            aria-label="每週門診時刻"
          >
            {
              displaySchedule.map((s) => (
                <div
                  class="grid grid-cols-4 gap-2 sm:gap-4 items-center text-center group hover:bg-highlight/20 rounded-xl transition-colors py-2 px-1"
                  role="listitem"
                >
                  <div class="font-bold text-primary text-sm sm:text-base group-hover:text-accent transition-colors">
                    {s.day}
                  </div>
                  <div
                    class={`text-xs sm:text-sm py-2 sm:py-3 rounded-xl flex flex-col justify-center items-center transition-all ${getStatusClass(s.morning?.status)}`}
                  >
                    <span>{getStatusLabel(s.morning)}</span>
                    {s.morning?.note && (
                      <span class="text-[0.6rem] opacity-80 mt-0.5 font-normal leading-tight">
                        {s.morning.note}
                      </span>
                    )}
                  </div>
                  <div
                    class={`text-xs sm:text-sm py-2 sm:py-3 rounded-xl flex flex-col justify-center items-center transition-all ${getStatusClass(s.afternoon?.status)}`}
                  >
                    <span>{getStatusLabel(s.afternoon)}</span>
                    {s.afternoon?.note && (
                      <span class="text-[0.6rem] opacity-80 mt-0.5 font-normal leading-tight">
                        {s.afternoon.note}
                      </span>
                    )}
                  </div>
                  <div
                    class={`text-xs sm:text-sm py-2 sm:py-3 rounded-xl flex flex-col justify-center items-center transition-all ${getStatusClass(s.evening?.status)}`}
                  >
                    <span>{getStatusLabel(s.evening)}</span>
                    {s.evening?.note && (
                      <span class="text-[0.6rem] opacity-80 mt-0.5 font-normal leading-tight">
                        {s.evening.note}
                      </span>
                    )}
                  </div>
                </div>
              ))
            }
          </div>

          <div
            class="mt-8 p-4 bg-highlight/30 rounded-xl border border-highlight/50 text-sm text-text/70 leading-relaxed flex gap-3 mt-auto"
          >
            <span
              class="text-accent font-black shrink-0 mt-0.5"
              aria-hidden="true">!</span
            >
            <p>
              實際看診時間可能因會議或手術有所異動，建議來院前先透過電話確認。
            </p>
          </div>
        </div>
      </div>
    </div>

    {/* ── 下半部：交通與聯絡資訊 ── */}
    <div>
      <div class="mb-10 text-center">
        <p
          class="text-xs font-bold tracking-[0.2em] uppercase text-accent mb-3 flex items-center justify-center gap-2"
        >
          <MapPin size={14} aria-hidden="true" /> LOCATION
        </p>
        <h2 class="text-3xl md:text-4xl font-serif font-bold text-primary">
          交通與聯絡資訊
        </h2>
      </div>

      <div
        class="grid grid-cols-1 lg:grid-cols-2 gap-6 lg:gap-8 max-w-6xl mx-auto items-stretch"
      >
        {/* 左欄：操作按鈕 + 地址與交通卡片 */}
        <div class="flex flex-col gap-5">
          {/* 快捷按鈕列 */}
          <div class="grid grid-cols-2 gap-4">
            {/* 撥打電話 */}
            <a
              href={clinicData.callLink}
              aria-label={`撥打診所電話 ${clinicData.phone}`}
              class="flex flex-col items-center justify-center text-center py-8 px-4 bg-primary text-white rounded-3xl shadow-lg hover:brightness-110 active:scale-95 transition-all duration-200 group focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent"
            >
              <Phone
                size={36}
                strokeWidth={2}
                className="mb-3 opacity-90 group-hover:scale-110 transition-transform duration-200"
                aria-hidden="true"
              />
              <span class="text-xl font-bold tracking-wide mb-1">撥打電話</span>
              <span class="text-sm font-semibold opacity-85 tracking-wider"
                >{clinicData.phone}</span
              >
            </a>

            {/* Google 導航 */}
            <a
              href={clinicData.navigationLink}
              target="_blank"
              rel="noopener noreferrer"
              aria-label="開啟 Google 地圖導航前往診所"
              class="flex flex-col items-center justify-center text-center py-8 px-4 bg-white text-primary border-2 border-gray-200 rounded-3xl shadow-md hover:border-primary hover:shadow-xl active:scale-95 transition-all duration-200 group focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent"
            >
              <Navigation
                size={36}
                strokeWidth={2}
                className="mb-3 text-primary group-hover:scale-110 transition-transform duration-200"
                aria-hidden="true"
              />
              <span class="text-xl font-bold tracking-wide mb-1">Google</span>
              <span
                class="text-xl font-bold tracking-widest text-accent group-hover:text-primary transition-colors"
                >導航前往</span
              >
            </a>
          </div>

          {/* 地址 + 交通資訊卡片 */}
          <address
            class="not-italic bg-white rounded-3xl p-6 sm:p-8 shadow-md border border-gray-100 flex-grow"
          >
            {/* 地址列 */}
            <div class="flex items-start gap-4 mb-6">
              <div
                class="w-10 h-10 rounded-2xl bg-blue-50 border border-blue-100 flex items-center justify-center text-primary shrink-0 mt-0.5"
                aria-hidden="true"
              >
                <MapPin size={20} strokeWidth={2.5} />
              </div>
              <div>
                <h3
                  class="text-xs font-bold text-text/40 uppercase tracking-widest mb-1.5"
                >
                  地址
                </h3>
                <p
                  class="text-base sm:text-lg text-primary font-semibold leading-snug"
                >
                  {clinicData.address}
                </p>
              </div>
            </div>

            <div class="w-full h-px bg-gray-100 mb-6" aria-hidden="true"></div>

            {/* 交通方式列 */}
            <div class="flex items-start gap-4">
              <div
                class="w-10 h-10 rounded-2xl bg-blue-50 border border-blue-100 flex items-center justify-center text-primary shrink-0 mt-0.5"
                aria-hidden="true"
              >
                <Bus size={20} strokeWidth={2.5} />
              </div>
              <div class="flex-1 min-w-0">
                <h3
                  class="text-xs font-bold text-text/40 uppercase tracking-widest mb-4"
                >
                  交通方式
                </h3>
                <ul
                  class="space-y-5 text-sm sm:text-[15px] text-text/80 leading-relaxed"
                >
                  {/* 捷運 */}
                  <li class="flex items-start gap-3">
                    <span
                      class="w-7 h-7 rounded-full bg-green-100 flex items-center justify-center shrink-0 mt-0.5"
                      aria-hidden="true"
                    >
                      <Train
                        size={14}
                        strokeWidth={2.5}
                        className="text-green-700"
                      />
                    </span>
                    <p>
                      <strong class="text-primary font-bold">捷運｜</strong>
                      松山新店線 ／ 環狀線「大坪林站」1 號出口，出站後步行約 1 分鐘即可抵達。
                    </p>
                  </li>

                  {/* 公車 */}
                  <li class="flex items-start gap-3">
                    <span
                      class="w-7 h-7 rounded-full bg-orange-100 flex items-center justify-center shrink-0 mt-0.5"
                      aria-hidden="true"
                    >
                      <Bus
                        size={14}
                        strokeWidth={2.5}
                        className="text-orange-600"
                      />
                    </span>
                    <p>
                      <strong class="text-primary font-bold">公車｜</strong>
                      「捷運大坪林站」或「民權路口」站下車，多線公車可達，步行數分鐘內可抵達。
                    </p>
                  </li>

                  {/* 機車 */}
                  <li class="flex items-start gap-3">
                    <span
                      class="w-7 h-7 rounded-full bg-blue-100 flex items-center justify-center shrink-0 mt-0.5"
                      aria-hidden="true"
                    >
                      <Bike
                        size={14}
                        strokeWidth={2.5}
                        className="text-blue-600"
                      />
                    </span>
                    <p>
                      <strong class="text-primary font-bold">機車｜</strong>
                      診所門前設有機車就診專用停車區，供來院患者使用。
                    </p>
                  </li>

                  {/* 開車 */}
                  <li class="flex items-start gap-3">
                    <span
                      class="w-7 h-7 rounded-full bg-gray-100 flex items-center justify-center shrink-0 mt-0.5"
                      aria-hidden="true"
                    >
                      <CarFront
                        size={14}
                        strokeWidth={2.5}
                        className="text-gray-600"
                      />
                    </span>
                    <div class="min-w-0">
                      <p class="mb-3">
                        <strong class="text-primary font-bold">開車｜</strong>
                        周邊設有路邊停車格及收費停車場，建議停放於以下地點：
                      </p>
                      <ul
                        class="space-y-2 text-[13px] sm:text-sm bg-gray-50 rounded-2xl p-4 border border-gray-100"
                      >
                        <li
                          class="flex items-start gap-2.5 text-text/70 leading-normal"
                        >
                          <span
                            class="w-1.5 h-1.5 rounded-full bg-accent mt-2 shrink-0"
                            aria-hidden="true"></span>
                          江陵禮停車場（新北市新店區民權路 67 號；入口位於玉山銀行旁）
                        </li>
                        <li
                          class="flex items-start gap-2.5 text-text/70 leading-normal"
                        >
                          <span
                            class="w-1.5 h-1.5 rounded-full bg-accent mt-2 shrink-0"
                            aria-hidden="true"></span>
                          Times 佳瑪新店店停車場（新北市新店區民權路 42 巷 59 弄 53
                          號）
                        </li>
                      </ul>
                    </div>
                  </li>
                </ul>
              </div>
            </div>
          </address>
        </div>

        {/* 右欄：滿版地圖 */}
        <div
          class="relative bg-white rounded-3xl overflow-hidden shadow-md border border-gray-100 min-h-[420px] lg:min-h-0 lg:h-auto"
        >
          {/* 放大地圖按鈕 */}
          <a
            href={clinicData.mapLink}
            target="_blank"
